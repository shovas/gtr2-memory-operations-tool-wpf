<Window x:Class="Gtr2MemOpsTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gtr2MemOpsTool"
        xmlns:views="clr-namespace:Gtr2MemOpsTool.Views"
        mc:Ignorable="d"
        Title="GTR2 Memory Operations Tool" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Menu Grid.Row="0" Grid.Column="0" VerticalAlignment="Top" VerticalContentAlignment="Center">
            <MenuItem Header="File">
                
                <MenuItem Header="Exit" Click="MenuItem_File_Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Edit"/>
            <MenuItem Header="View"/>
            <MenuItem Header="Tools"/>
            <MenuItem Header="Process">
                <MenuItem Header="Check GTR2 Process" Click="MenuItem_Process_Check_Click"/>
            </MenuItem>
            <MenuItem Header="Tests">
                <MenuItem Header="Test Get GTR2 Process" Click="MenuItem_Tests_TestGetProcess"/>
                <MenuItem Header="Test Open GTR2 Process" Click="MenuItem_Tests_TestOpenProcess" />
                <MenuItem Header="[Not Yet Implemented] Test Read GTR2 Process"/>
                <MenuItem Header="[Not Yet Implemented] Test Write GTR2 Process"/>
                <MenuItem Header="Test GTR2 Process" Click="MenuItem_Tests_TestGTR2Process"/>
                <Separator/>
                <MenuItem Header="Test GTR2 Shared Memory" Click="MenuItem_Tests_TestSharedMemory"/>
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="About" Click="MenuItem_Help_About_Click"/>
                <MenuItem Header="Support My Work via SimWiki.net" Click="MenuItem_Help_SupportMyWork_Click"/>
            </MenuItem>
        </Menu>
        <TabControl x:Name="MainTabControl" Grid.Row="1" Grid.Column="0">
            <TabItem x:Name="AutomaticAiTab"  Header="Automatic AI">
                <views:AutomaticAiView x:Name="AutomaticAiView"/>
            </TabItem>
            <!--<TabItem x:Name="StatusTab" Header="Home">
                <views:StatusView x:Name="StatusView" VerticalAlignment="Stretch"/>
            </TabItem>-->
            <!--<TabItem x:Name="HomeTab" Header="Home">
                <views:HomeView x:Name="HomeView" VerticalAlignment="Stretch"/>
            </TabItem>-->
            <TabItem x:Name="SharedMemoryTab" Header="Shared Memory">
                <views:SharedMemoryView x:Name="SharedMemoryView"/>
            </TabItem>
            <TabItem x:Name="ProgramMemoryTab" Header="Program Memory">
                <views:ProgramMemoryView x:Name="ProgramMemoryView"/>
            </TabItem>
            <TabItem x:Name="LogTab"  Header="Log">
                <views:LogView x:Name="LogView"/>
            </TabItem>
            <TabItem x:Name="SettingsTab" Header="Settings">
                <views:SettingsView x:Name="SettingsView"/>
            </TabItem>
        </TabControl>
        <StatusBar x:Name="StatusBar" Grid.Row="2" Grid.Column="0">
            <StatusBarItem x:Name="StatusBarItem" Height="22">
                <TextBlock x:Name="StatusBarItemText" Text="Ready" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
