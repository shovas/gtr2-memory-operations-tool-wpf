<Window x:Class="Gtr2MemOpsTool.Windows.EditProgramMemoryItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gtr2MemOpsTool.Windows"
        mc:Ignorable="d"
        Title="Edit Program Memory Item" Height="90" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <TextBox x:Name="ValueTextBox" TextWrapping="Wrap" Text="{Binding Value}" VerticalAlignment="Center" Margin="5,0,5,0"/>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="0" Background="#EEE" VerticalAlignment="Center" HorizontalAlignment="Right">
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Background="White">
                <Button x:Name="SaveButton" Content="Save" Click="SaveButton_Click" Height="20" Margin="5,5,5,5" Padding="5,0,5,0"/>
                <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Height="20" Margin="5,5,5,5" Padding="5,0,5,0"/>
            </StackPanel>
        </Grid>
        
    </Grid>
</Window>
