<UserControl x:Class="Gtr2MemOpsTool.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gtr2MemOpsTool.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!--<TextBlock Text="Log View" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>-->
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0" Background="#EEE" VerticalAlignment="Center">
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Background="White">
                <Button x:Name="ClearLogButton" Content="Clear Log" Click="ClearLogButton_Click" Height="20" Margin="5,5,5,5" Padding="5,0,5,0"/>
                <Button x:Name="CopyLogButton" Content="Copy Log" Click="CopyLogButton_Click" Height="20" Margin="5,5,5,5" Padding="5,0,5,0"/>
                <Button x:Name="SaveLogButton" Content="Save Log" Click="SaveLogButton_Click" Height="20" Margin="5,5,5,5" Padding="5,0,5,0"/>
                <TextBlock Text="Log Level:" VerticalAlignment="center" Margin="5,5,5,5" FontSize="14"/>
                <ComboBox x:Name="LogFilterSelector" Width="150" SelectionChanged="LogFilterSelector_SelectionChanged" VerticalAlignment="center" VerticalContentAlignment="center" HorizontalAlignment="center" HorizontalContentAlignment="Left" Height="20" Margin="5,5,5,5" Padding="5,0,5,0">
                    <ComboBoxItem Content="Exception only" Tag="Exception"/>
                    <ComboBoxItem Content="Error and above" Tag="Error"/>
                    <ComboBoxItem Content="Warning and above" Tag="Warning"/>
                    <ComboBoxItem Content="Info and above" Tag="Info"/>
                    <ComboBoxItem Content="Debug and above" Tag="Debug"/>
                </ComboBox>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="0">
            <!--<TextBox x:Name="LogBox" TextWrapping="Wrap" Text="" VerticalAlignment="Stretch" VerticalScrollBarVisibility="Visible" IsReadOnly="True" IsUndoEnabled="False" AcceptsReturn="True" SpellCheck.IsEnabled="False" AcceptsTab="False"/>-->
            <ListView x:Name="LogListView" ItemsSource="{Binding LogItems}" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Timestamp" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Level" Width="75" DisplayMemberBinding="{Binding LogLevel}"/>
                        <GridViewColumn Header="Message" Width="300" DisplayMemberBinding="{Binding Message}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
