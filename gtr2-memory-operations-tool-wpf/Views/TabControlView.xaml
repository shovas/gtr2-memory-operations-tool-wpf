<UserControl x:Class="gtr2_memory_operations_tool_wpf.Views.TabControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:gtr2_memory_operations_tool_wpf.Views"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!--xmlns:vm="clrt-namespace:gtr2_memory_operations_tool_wpf.ViewModels"-->
    <UserControl.DataContext>
        <!--<vm:TabControlViewModel/>-->
        <vm:TabControlViewModel xmlns:vm="clr-namespace:gtr2_memory_operations_tool_wpf.ViewModels"/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <TabControl x:Name="TabControl" Margin="0,18,0,0"
                    ItemsSource="{Binding TabItems}"
                    TabStripPlacement="Top"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="IsItemsHost" Value="True"/>
                </Style>
            </TabControl.Resources>
        </TabControl>
        <!--<Button Content="Test" Width="100" Height="50"/>-->
    </Grid>
</UserControl>
