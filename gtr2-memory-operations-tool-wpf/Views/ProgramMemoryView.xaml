<UserControl x:Class="Gtr2MemOpsTool.Views.ProgramMemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gtr2MemOpsTool.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0" Grid.Column="0">
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Background="White">
                <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" Height="20" Margin="5,5,5,5" Padding="5,0,5,0"/>
                <TextBlock Text="Search:" VerticalAlignment="center" Margin="5,5,5,5" FontSize="14"/>
                <TextBox x:Name="SearchFilterBox" Width="150" VerticalAlignment="center" VerticalContentAlignment="center" HorizontalAlignment="center" HorizontalContentAlignment="Left" Height="20" Margin="5,5,5,5" Padding="0,0,0,0" TextChanged="SearchFilterBox_TextChanged"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="0">
            <ListView ItemsSource="{Binding MemoryItems}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Key" Width="200" DisplayMemberBinding="{Binding Key}"/>
                        <GridViewColumn Header="Value" Width="200" DisplayMemberBinding="{Binding Value}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
